# ============================================================
# AI Course .gitignore
# ============================================================

# SECURITY: Never commit these
.env
*.key
secrets.json
api_keys.txt

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg

# Virtual environments
venv/
env/
.venv/
ai_course_env/

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb

# Data and cache files (can be large)
cache/
*.json
!.env.example
logs/
*.log

# Vector database storage (rebuild from source)
my_knowledge_base/
rag_index/
lc_rag/
private_rag/
ca_knowledge_base/
*.faiss
*.pkl

# Audio/media (usually large)
*.mp3
*.mp4
*.wav
*.m4a

# OS files
.DS_Store
Thumbs.db
*.swp

# IDE
.vscode/
.idea/
*.sublime-project
